/*
   TYPE RAMP  (UX-H06)
   ----------------------------------------
   Display    : 64px  - Hero title (SpaceGrotesk-SemiBold)
   Panel-title: 36px  - Panel / mode headings
   H1         : 28px  - Section titles, about title
   Sheet-title: 24px  - Sheet header, app logo
   H2         : 20px  - Panel headings, hero subtitle
   Body-lg    : 18px  - Card titles, sub-headings
   Body       : 16px  - Buttons, body text
   Body-sm    : 14px  - Descriptions, secondary text, data rows
   Caption    : 12px  - Counters, foldout labels

   FONTS:
   SpaceGrotesk-SemiBold  - Display, hero titles
   SpaceGrotesk-SemiBold - Sheet titles, emphasis
   SpaceGrotesk-Regular  - Section headings
   Inter-Regular         - All body text (base)
   ---------------------------------------- */
/* ============================================================
   WebGL Drone Viewer â€” Main Theme Stylesheet
   2026 Futuristic Minimalist Â· 8pt Grid Â· HIG/MD3 Compliant
   ============================================================ */

/* Import Modules */
@import "Hotspots.uss";

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   Design Tokens (Direct Values â€” USS has no vars)
   Aligned with web landing page (docs/src/index.css)
   
   Background:     rgb(0, 0, 0)             #000000
   Surface:        rgba(1, 1, 1, 0.92)   #010101
   Primary:        rgb(255, 255, 255)       White (matches web --accent)
   On-Surface:     rgb(255, 255, 255)       White
   On-Surface-Dim: rgba(255, 255, 255, 0.65) Muted (WCAG 4.5:1 on #000000)
   Border:         rgba(255, 255, 255, 0.1)
   Border-Hover:   rgba(255, 255, 255, 0.2) White
   Radius-Pill:    half of height (56pxâ†’28, 112pxâ†’56)
   Radius-LG:      24px  (bottom sheet)
   Radius-MD:      16px  (cards, sliders, containers)
   Radius-SM:      12px  (glass panels, sidebar)
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   Base Root
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.root {
    flex-grow: 1;
    background-color: rgb(0, 0, 0);
    color: rgb(255, 255, 255);
    -unity-font-definition: initial;
    -unity-font: resource("Fonts/Inter/Inter-Regular");
    font-size: 24px;
}

/* Full Screen Overlay */
.app-container {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    opacity: 0;

    transition-property: opacity;
    transition-duration: 0.8s;
}

.app-container--active {
    opacity: 1;

}

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   Hero / Landing Screen
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.hero-container {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    align-items: center;
    justify-content: center;
    background-color: rgb(0, 0, 0);
    transition-property: opacity;
    transition-duration: 0.5s;
}

.hero-title {
    font-size: 64px;
    -unity-font-definition: initial;
    -unity-font: resource("Fonts/SpaceGrotesk/SpaceGrotesk-Light");
    -unity-font-style: bold;
    color: white;
    margin-bottom: 16px;
    letter-spacing: -1px;
}

.hero-subtitle {
    font-size: 20px;
    color: rgba(255, 255, 255, 0.35);
    margin-bottom: 48px;
    letter-spacing: 1px;
}

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   Root Container
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.root-container {
    flex-grow: 1;
    background-color: transparent;
    justify-content: space-between;
}

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   Top Bar (Header)
   Height: 64px (8pt grid), margin-top: 80px safe area
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.top-bar {
    height: 56px;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    background-color: transparent;
    margin-top: 24px;
}

.header-title {
    font-size: 20px;
    color: rgba(255, 255, 255, 0.65);
    -unity-font-style: bold;
    letter-spacing: 4px;
}

#HomeBtn {
    position: absolute;
    left: 24px;
    top: 50%;
    translate: 0 -50%;
}

#ResetViewBtn {
    position: absolute;
    right: 24px;
    top: 50%;
    translate: 0 -50%;
}

/* HotspotBtn moved to Category Menu */

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   Bottom Bar (Controls â€” Thumb Zone)
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.bottom-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    flex-direction: column;
    align-items: center;
    background-color: transparent;
    padding-bottom: 0;

    /* Smooth shift for sheet */
    transition-property: bottom, translate;
    transition-duration: 0.3s;
    transition-timing-function: ease-out;
}

/* Actions Row â€” The Unified Glass Pill */
.actions-row {
    flex-direction: row;
    justify-content: center;
    align-items: center;
    
    background-color: transparent;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.3);
    border-radius: 56px; /* True pill: half of 112px height â€” matches .btn pill language */
    padding: 0 48px;
    min-width: 480px;
    height: 112px;
    
    margin-bottom: 8px;
    
    transition-property: width, opacity, translate;
    transition-duration: 0.3s;
}

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   Icon Buttons (Inside Pill)
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.icon-button {
    width: 64px;
    height: 64px;
    margin-left: 8px;
    margin-right: 8px;

    /* Transparent by default inside pill */
    background-color: transparent;
    border-radius: 50%;
    border-width: 0;
    border-color: transparent;

    justify-content: center;
    align-items: center;

    transition-property: background-color, scale, color;
    transition-duration: 0.2s;
    transition-timing-function: ease-out;
}

.icon-button:hover {
    background-color: rgba(255, 255, 255, 0.1);
    scale: 1.1;
}

.icon-button:active {
    scale: 0.95;
    background-color: rgba(255, 255, 255, 0.2);
}

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   Mode Buttons (3-Mode System: Explore, Analyze, Studio)
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.mode-btn {
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 120px;
    height: 96px;
    margin-left: 12px;
    margin-right: 12px;
    
    background-color: transparent;
    border-radius: 0;
    border-width: 0;
    border-color: transparent;
    
    transition-property: scale, opacity;
    transition-duration: 0.25s;
    transition-timing-function: ease-out;
}

.mode-btn:hover {
    background-color: transparent;
    border-color: transparent;
    scale: 1.1;
}

.mode-btn:active {
    scale: 0.92;
    background-color: transparent;
}

.mode-btn--active {
    background-color: transparent;
    border-width: 0;
}

.mode-btn--active .mode-btn-icon {
    -unity-background-image-tint-color: rgba(70, 175, 255, 1);
}

.mode-btn--active:hover {
    background-color: transparent;
    border-color: transparent;
}

.mode-btn-icon {
    width: 56px;
    height: 56px;
    -unity-background-scale-mode: scale-to-fit;
    margin-bottom: 8px;
}

.mode-btn-label {
    font-size: 18px;
    color: rgba(255, 255, 255, 0.65);
    letter-spacing: 1px;
    -unity-font-style: bold;
}

.mode-btn--active .mode-btn-label {
    color: rgba(70, 175, 255, 0.9);
}

/* Mode-specific icons */
.icon-explore { background-image: resource("UI/Icons/icon_explore"); }
.icon-analyze { background-image: resource("UI/Icons/icon_analyze"); }
.icon-studio  { background-image: resource("UI/Icons/icon_studio"); }
.icon-cross-section { background-image: resource("UI/Icons/icon_cross_section"); }

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   Mode Containers (above bottom bar, contextual tool panels)
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.mode-container {
    /* Now lives INSIDE BottomBar â€” no absolute positioning */
    flex-direction: column;
    align-items: center;
    align-self: center;
    
    width: 680px;
    max-width: 92%;
    
    background-color: transparent;
    margin-bottom: 8px;
    
    transition-property: opacity, scale;
    transition-duration: 0.3s;
    transition-timing-function: ease-out;
}

.mode--hidden {
    display: none;
    opacity: 0;
    scale: 0.96 0.96;
}

/* Submenus inside mode-containers: override absolute positioning */
.mode-submenu {
    position: relative;
    bottom: auto;
    left: auto;
    translate: 0 0;
    
    width: 100%;
    
    background-color: transparent;
    border-width: 0;
    border-radius: 0;
    padding: 8px 0;
    
    align-items: center;
    margin-bottom: 8px;
    
    transition-property: opacity, translate, scale;
    transition-duration: 0.25s;
    transition-timing-function: ease-out;
}

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   Mode Action Bar (tool buttons inside each mode container)
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.mode-action-bar {
    flex-direction: row;
    align-items: center;
    justify-content: center;
    padding: 8px 0;
    margin-bottom: 8px;
    background-color: transparent;
    border-radius: 0;
    border-width: 0;
}

.mode-action-btn {
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 64px;
    margin-left: 12px;
    margin-right: 12px;
    background-color: transparent;
    border-radius: 0;
    border-width: 0;
    transition-property: scale;
    transition-duration: 0.2s;
    transition-timing-function: ease-out;
}

.mode-action-btn:hover {
    background-color: transparent;
    scale: 1.1;
}

.mode-action-btn:active {
    scale: 0.92;
    background-color: transparent;
}

.mode-action-btn--active {
    background-color: transparent;
    border-width: 0;
}

.mode-action-btn--active .mode-action-icon {
    -unity-background-image-tint-color: rgba(70, 175, 255, 1);
}

.mode-action-btn--active:hover {
    background-color: transparent;
}

.mode-action-icon {
    width: 40px;
    height: 40px;
    margin-bottom: 4px;
}

.mode-action-label {
    font-size: 18px;
    color: rgba(255, 255, 255, 0.65);
    letter-spacing: 1px;
    -unity-font-style: bold;
}

.mode-action-btn--active .mode-action-label {
    color: rgba(70, 175, 255, 0.9);
}

/* Icon references for mode action buttons (removed) */

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   Cross-Section Panel (inside Analyze Mode)
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.cross-section-panel {
    width: 100%;
    align-items: center;
}

.cross-section-row {
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    width: 100%;
}

.cross-section-toggle {
    min-width: 88px;
    margin-right: 0;
    margin-bottom: 8px;
}

.cross-section-controls {
    flex-direction: column;
    align-items: center;
    flex-grow: 0;
    width: 100%;
    
    transition-property: opacity;
    transition-duration: 0.25s;
    transition-timing-function: ease-out;
}

.cross-section-axis-group {
    flex-direction: row;
    flex-wrap: nowrap;
    justify-content: flex-start;
    width: 476px;
    align-self: center;
    margin-right: 0;
    margin-bottom: 8px;
}

.cross-section-axis-btn {
    width: 104px;
    height: 56px;
    margin: 0 4px;
    
    background-color: transparent;
    border-radius: 12px;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.1);
    
    flex-direction: column;
    justify-content: center;
    align-items: center;
    
    transition-property: border-color, scale;
    transition-duration: 0.2s;
    transition-timing-function: ease-out;
}

.cross-section-axis-btn:hover {
    border-color: rgba(255, 255, 255, 0.2);
    scale: 1.04;
}

.cross-section-axis-btn:active {
    scale: 0.92;
}

.cross-section-axis-btn.submenu-card--active {
    border-color: rgba(70, 175, 255, 1);
}

.cross-section-axis-label {
    font-size: 18px;
    color: rgba(255, 255, 255, 0.65);
    -unity-font-style: bold;
    -unity-text-align: middle-center;
}

.cross-section-axis-btn.submenu-card--active .cross-section-axis-label {
    color: rgba(70, 175, 255, 1);
}

.cross-section-slider {
    width: 476px;
    height: 56px;
    min-height: 56px;
    align-self: center;
    margin: 0;
    padding: 0 16px;
    background-color: transparent;
    border-width: 0;
    flex-grow: 0;
}

/* .icon-cross-section handled procedurally */

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   Icon Buttons (100px â€” exceeds 48dp minimum)
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
/* Old .icon-button styles removed â€” see above */

/* Specific Buttons Icons */
/* HomeBtn, ResetViewBtn, HotspotBtn handled procedurally */

/* Phase 2 Cleanup: #ShaderBtn, #LayerBtn, #ExplodeBtn, #InfoBtn, #EnvBtn removed
   â€” old 5-button toolbar replaced by 3-mode system (ModeExploreBtn/ModeAnalyzeBtn/ModeStudioBtn) */

/* Hide text when icon is present, or make it minimal */
.button-icon-text, .button-icon-text-small {
    display: none;
}

/* Ensure background scales correctly */
.icon-button, .icon-button-small, .btn-tag {
    -unity-background-scale-mode: scale-to-fit;
    /* In Unity 6 this might be slightly different property name depending on version, generic is safe */
}

/* Small Icon Button (Top Bar â€” Reset, Home, Hotspot) */
.icon-button-small {
    width: 64px;
    height: 64px;
    background-color: transparent;
    border-radius: 50%;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.1);
    justify-content: center;
    align-items: center;
    transition-property: border-color, background-color, scale;
    transition-duration: 0.2s;
    margin-right: 12px;
}

.icon-button-small:hover {
    border-color: rgba(255, 255, 255, 0.2);
}

.icon-button-small:active {
    scale: 0.94;
    border-color: rgba(255, 255, 255, 0.3);
}

.button-icon-text-small {
    font-size: 20px;
    color: white;
}

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   Selection Label (Below Buttons)
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.info-row {
    flex-direction: row;
    justify-content: center;
    align-items: center;
    height: 32px;
    margin-bottom: 4px;
}

.selection-label {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.75);
    -unity-font-style: bold;
    letter-spacing: 1px;

    background-color: rgba(255, 255, 255, 0.10);
    padding: 8px 16px;
    border-radius: 16px;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.15);

    /* Smooth fade â€” NO display:none */
    opacity: 1;
    transition-property: opacity;
    transition-duration: 0.3s;
    transition-timing-function: ease-out;
}

.selection-label--hidden {
    opacity: 0;

}

/* â”€â”€ Hero Submenus (Full Screen Overlays) â”€â”€ */
.hero-submenu {
    position: absolute;
    width: 100%;
    height: 100%;
    background-color: #000000;
    display: none;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition-duration: 0.3s;
    transition-property: opacity;
    padding: 0 48px;
}

.hero-submenu--active {
    display: flex;
    opacity: 1;
}

.btn-back {
    position: absolute;
    top: 32px;
    left: 24px;
    width: 64px;
    height: 64px;
    background-color: transparent;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    -unity-font-definition: initial;
    -unity-font: resource("Fonts/Inter/Inter-Regular");
    font-size: 24px;
    color: white;
    justify-content: center;
    align-items: center;
    transition-property: border-color, background-color, scale;
    transition-duration: 0.2s;
}

.btn-back:hover {
    border-color: rgba(255, 255, 255, 0.2);
}

.btn-back:active {
    scale: 0.94;
    border-color: rgba(255, 255, 255, 0.3);
}

.submenu-scroll {
    width: 600px;
    max-height: 70%;
    margin-top: 24px;
}

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   Bottom Sheet (Details Panel)
   Slides up from bottom. Buttons sit above via z-order.
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.details-sheet {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 55%;

    background-color: rgba(0, 0, 0, 0.96);
    border-top-left-radius: 24px;
    border-top-right-radius: 24px;
    border-top-width: 1px;
    border-top-color: rgba(255, 255, 255, 0.08);
    padding: 80px 24px 40px 24px;
    overflow: hidden;

    translate: 0 0;
    transition-property: translate;
    transition-duration: 0.3s;
    transition-timing-function: ease-out;
}

.details-sheet--hidden {
    translate: 0 100%;
    opacity: 1;
}

.sheet-handle {
    width: 40px;
    height: 4px;
    background-color: rgba(255, 255, 255, 0.16);
    border-radius: 2px;
    align-self: center;
    margin-bottom: 16px;
}

.sheet-header {
    margin-bottom: 4px;
    flex-direction: row;
    position: relative;
    justify-content: space-between;
    align-items: center;
}

.sheet-title {
    font-size: 24px;
    -unity-font-definition: initial;
    -unity-font: resource("Fonts/SpaceGrotesk/SpaceGrotesk-Regular");
    -unity-font-style: normal;
    color: white;
    margin-bottom: 0;
    letter-spacing: -0.5px;
}

.sheet-hint {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.65);
    -unity-font-style: italic;
}

.sheet-content {
    opacity: 1;
    transition-duration: 0.2s;
    flex-grow: 1;
}

.read-only-text {
    background-color: transparent;
    border-width: 0;
    margin: 0;
    padding: 0;
    -unity-font-style: normal;
    color: rgba(255, 255, 255, 0.9);
    white-space: normal; /* text-wrap in new Unity */
}

.read-only-text > .unity-text-field__input {
    background-color: transparent;
    border-width: 0;
    padding: 0;
    white-space: normal;
}

/* Force right alignment for data values converted to text fields */
.data-value.read-only-text > .unity-text-field__input {
    -unity-text-align: middle-right;
}

/* Sheet Close Button — see canonical definition at bottom of file */

.sheet-scroll {
    flex-grow: 1;
    margin-top: 8px;
}

/* UI Shift on Sheet Expand (Full Height) â€” moves bottom bar up above the sheet */
.ui-shifted {
    bottom: 55%;      /* Match panel height so bar bottom = panel top */
    translate: 0 64px; /* Compensate pill offset (0 pad + 8 margin + 56 half-height) */
}

/* UI Soft Shift (When Peek Bar spawns) â€” nudges bottom bar slightly up */
.ui-shifted-soft {
    bottom: 40px;
    translate: 0 -12px; /* Push up just 12px for perfect Gestalt grouping without Fitts violation */
}

/* Pill bar becomes opaque when sheet is open to prevent content bleeding through */
.actions-row--sheet-open {
    background-color: rgba(0, 0, 0, 0.96);
    border-color: rgba(255, 255, 255, 0.08);
    transition-property: background-color, border-color;
    transition-duration: 0.3s;
}

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   Unified Grid Submenus (Shader, Category, etc.)
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.submenu-container {
    position: absolute;
    bottom: 300px;
    left: 50%;
    translate: -50% 0;
    
    background-color: rgba(255, 255, 255, 0.08);
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.12);
    border-radius: 16px;
    padding: 16px;
    
    width: 680px;
    max-width: 92%;
    
    align-items: center;
    
    transition-property: opacity, translate, scale;
    transition-duration: 0.25s;
    transition-timing-function: ease-out;
}

.submenu--hidden {
    opacity: 0;
    scale: 0.95 0.95;
    translate: 0 8px;
    display: none;
}

.submenu-title {
    font-size: 20px;
    color: rgba(255, 255, 255, 0.65);
    letter-spacing: 2px;
    margin-bottom: 12px;
    -unity-font-style: bold;
}

.submenu-grid {
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
    padding-left: 0;
    width: 476px;
    align-self: center;
}

/* Card Item (Button) */
.submenu-card {
    width: 148px;
    height: 148px;
    margin: 4px;
    
    background-color: transparent;
    border-radius: 16px;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.1);
    
    flex-direction: column;
    align-items: center;
    justify-content: center;
    
    transition-property: border-color, scale;
    transition-duration: 0.15s;
}

.submenu-card:hover {
    border-color: rgba(255, 255, 255, 0.2);
    scale: 1.04;
}

.submenu-card:active {
    border-color: rgba(255, 255, 255, 0.3);
    scale: 0.98;
}

.submenu-card--active {
    border-color: rgba(70, 175, 255, 1);
}

.submenu-icon {
    width: 56px;
    height: 56px;
    margin-bottom: 8px;
    -unity-background-scale-mode: scale-to-fit;
    -unity-background-image-tint-color: rgba(255, 255, 255, 0.65);
}

.submenu-label {
    font-size: 18px;
    color: rgba(255, 255, 255, 0.65);
    letter-spacing: 0.5px;
    -unity-text-align: middle-center;
}

.submenu-card--active .submenu-label {
    color: rgba(70, 175, 255, 1);
    -unity-font-style: bold;
}

.submenu-card--active .submenu-icon {
    -unity-background-image-tint-color: rgba(70, 175, 255, 1);
}

/* Specific Icons handled procedurally */

/* Section title spacing (Studio combined panel) */
.submenu-title--section {
    margin-top: 16px;
}

.btn-tag:hover {
    border-color: rgba(255, 255, 255, 0.3);
    color: white;
}

.btn-tag--active {
    background-color: rgb(255, 255, 255);
    border-color: rgb(255, 255, 255);
    color: rgb(0, 0, 0);
}

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   Explosion Slider
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.slider-container {
    position: relative;
    bottom: auto;
    left: auto;
    translate: 0 0;
    margin-left: 0;

    width: 480px;
    height: 56px;
    align-self: center;

    background-color: transparent;
    padding: 0 16px;
    border-width: 0;

    flex-direction: row;
    align-items: center;
    justify-content: center;
    margin-bottom: 8px;

    /* Smooth show/hide */
    opacity: 1;
    transition-duration: 0.25s;
    transition-property: opacity, translate, scale;
    transition-timing-function: ease-out;
}

.slider-hidden {
    display: none;
    opacity: 0;
    scale: 0.96 0.96;
}



/* slider-container--shifted-up removed â€” menus inside BottomBar now */

.slider-label {
    font-size: 18px;
    color: rgba(255, 255, 255, 0.65);
    letter-spacing: 1px;
    margin-right: 12px;
    -unity-font-style: bold;
    white-space: nowrap;
    flex-shrink: 0;
}

/* Slider Track/Dragger */
.glass-slider {
    min-height: 44px;
    margin: 0;
    padding: 0;
    flex-grow: 1;
    justify-content: center;
    align-items: center;
}

.glass-slider #unity-drag-container {
    height: 100%;
    justify-content: center;
    align-items: flex-start;
}

.glass-slider .unity-base-slider__tracker {
    background-color: rgba(255, 255, 255, 0.12);
    height: 4px;
    border-radius: 2px;
    border-width: 0;
    top: 50%;
    margin-top: -1px;
}

.glass-slider .unity-base-slider__dragger {
    /* Pure absolute sizing to prevent UI Toolkit anchoring offsets */
    width: 20px;
    height: 20px;
    margin-top: -10px;
    
    border-radius: 50%;
    
    /* Stroke-only with black fill (outline style) */
    background-color: rgb(0, 0, 0);
    border-width: 2px;
    border-color: rgba(255, 255, 255, 0.6);
    
    top: 50%;
    transition-property: width, height, margin-top, background-color, border-width, border-color;
    transition-duration: 0.15s;
}

.glass-slider .unity-base-slider__dragger:hover {
    /* Grow + solid white fill */
    width: 28px;
    height: 28px;
    margin-top: -14px;
    background-color: rgb(255, 255, 255);
    border-width: 0px;
    border-color: rgba(255, 255, 255, 0);
}

/* Blue accent while pointer is pressed (compound selector overrides :hover) */
.glass-slider .unity-base-slider__dragger:hover:active,
.glass-slider .unity-base-slider__dragger:active {
    width: 22px;
    height: 22px;
    margin-top: -11px;
    background-color: rgba(70, 175, 255, 1);
    border-width: 0px;
    border-color: rgba(70, 175, 255, 0);
}

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   Data Grid (Sheet Content)
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.data-row {
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
    padding: 8px 0;
    min-height: 44px;
}

.data-label {
    color: rgba(255, 255, 255, 0.4);
    font-size: 14px;
    letter-spacing: 1px;
    flex-shrink: 0;
    min-width: 100px;
}

.data-value {
    color: rgba(255, 255, 255, 0.8);
    font-size: 14px;
    -unity-font-style: bold;
    flex: 1;
    -unity-text-align: upper-right;
    white-space: normal;
}

.data-value-status {
    color: rgba(255, 255, 255, 0.9);
}

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   Glassmorphic Panel (Reusable)
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.glass-panel {
    background-color: rgba(1, 1, 1, 0.88);
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 24px;
    transition-property: background-color, border-color;
    transition-duration: 0.25s;
}

.glass-panel:hover {
    background-color: rgba(1, 1, 1, 0.92);
    border-color: rgba(255, 255, 255, 0.15);
}

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   Buttons (Generic)
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.btn {
    border-width: 1px;
    border-radius: 28px; /* Pill Radius (Half of Height: 56/2 = 28) - CHANGE CURVATURE HERE */
    padding: 0 40px;
    font-size: 16px;
    -unity-font-style: normal;
    letter-spacing: 4px; /* CHANGE TEXT SPACING HERE */
    transition-property: background-color, border-color, scale;
    transition-duration: 0.3s;
    transition-timing-function: ease-out;
    justify-content: center;
    align-items: center;
}

.btn-primary {
    background-color: transparent;
    border-color: rgba(255, 255, 255, 0.3);
    color: white;
    border-width: 1px;
}

.btn-primary:hover {
    background-color: rgba(255, 255, 255, 0.1);
    border-color: white;
    scale: 1.05;
}

.btn-ghost {
    background-color: transparent;
    border-color: rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.7);
    border-width: 1px;
}

.btn-ghost:hover {
    border-color: rgba(255, 255, 255, 0.3);
    color: white;
    background-color: rgba(255, 255, 255, 0.05);
}

.btn-icon {
    width: 48px;
    height: 48px;
    padding: 0;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.08);
    border-width: 1px;
    transition-property: border-color, background-color;
    transition-duration: 0.2s;
}

.btn-icon:hover {
    border-color: rgba(255, 255, 255, 0.2);
    background-color: rgba(255, 255, 255, 0.08);
}

.btn-wide {
    width: 380px; /* CHANGE WIDTH HERE */
    height: 56px; /* CHANGE HEIGHT HERE */
    margin-bottom: 16px;
}

.btn-full-width {
    width: 100%;
}

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   Utility / Tag Dots
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.tag-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
}

.tag-dot-accent {
    background-color: rgb(255, 255, 255);
}

.tag-dot-energy {
    background-color: rgb(33, 203, 255);
}

.tag-dot-mechanical {
    background-color: rgba(255, 255, 255, 0.4);
}

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   Sidebar (Desktop â€” Left Edge)
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.sidebar {
    position: absolute;
    left: 24px;
    top: 50%;
    translate: 0 -50%;
    background-color: rgba(1, 1, 1, 0.88);
    border-color: rgba(255, 255, 255, 0.08);
    border-width: 1px;
    border-radius: 12px;
    padding: 16px;
    width: 64px;
    align-items: center;
    transition-property: border-color;
    transition-duration: 0.25s;
}

.sidebar:hover {
    border-color: rgba(255, 255, 255, 0.2);
}

.sidebar-spacer {
    height: 24px;
}

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   Details Panel (Desktop â€” Right Side)
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.details-panel {
    position: absolute;
    right: 24px;
    top: 152px;
    bottom: 200px;
    width: 600px;
    background-color: rgba(0, 0, 0, 0.95);
    border-color: rgba(255, 255, 255, 0.08);
    border-width: 1px;
    border-radius: 12px;
    padding: 24px;
    translate: 110% 0;
    transition-property: translate;
    transition-duration: 0.4s;
    transition-timing-function: ease-out;
}

.details-panel--visible {
    translate: 0 0;
}

.panel-header {
    border-bottom-width: 1px;
    border-bottom-color: rgba(255, 255, 255, 0.08);
    padding-bottom: 16px;
    margin-bottom: 16px;
}

.panel-title {
    font-size: 36px;
    color: white;
    -unity-font-style: bold;
    margin-bottom: 8px;
}

.panel-subtitle {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.65);
    letter-spacing: 1px;
}

.panel-spacer {
    flex-grow: 1;
}

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   HUD Bars
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.hud-bar {
    position: absolute;
    left: 0;
    right: 0;
    height: 120px;
    flex-direction: row;
    align-items: center;
    padding: 0 32px;
    background-color: transparent;
}

.hud-top {
    top: 0;
    justify-content: space-between;
}

.hud-bottom {
    bottom: 0;
    justify-content: center;
    background-color: rgba(0, 0, 0, 0.6);
    padding-bottom: 24px;
}

.app-logo {
    font-size: 24px;
    -unity-font-style: bold;
    color: rgba(255, 255, 255, 0.6);
    letter-spacing: 4px;
}

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   Misc Text
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.reset-icon-label {
    color: rgba(255, 255, 255, 0.65);
}

/* Sheet description — editorial subtitle below part name */
.sheet-description {
    color: rgba(255, 255, 255, 0.45);
    font-size: 14px;
    white-space: normal;
    margin-bottom: 20px;
    padding-right: 48px;
    line-height: 20px;
}


/* ----------------------------------------------------------------
   Collapsible Sheet Sections (Foldout)
   ---------------------------------------------------------------- */
.sheet-foldout {
    margin-top: 8px;
    padding-top: 8px;
    border-top-width: 1px;
    border-top-color: rgba(255, 255, 255, 0.06);
}

.sheet-foldout--first {
    border-top-width: 0;
    margin-top: 0;
    padding-top: 0;
}

.sheet-foldout > .unity-foldout__toggle {
    margin: 0;
    padding: 0;
    min-height: 44px;
}

.sheet-foldout > .unity-foldout__toggle > .unity-toggle__input {
    flex-direction: row-reverse;
    justify-content: space-between;
}

.sheet-foldout > .unity-foldout__toggle > .unity-toggle__input > .unity-foldout__text {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.35);
    letter-spacing: 4px;
    -unity-font-style: bold;
}

.sheet-foldout > .unity-foldout__toggle > .unity-toggle__input > .unity-toggle__checkmark {
    background-color: transparent;
    border-width: 0;
    -unity-background-image-tint-color: rgba(255, 255, 255, 0.4);
    width: 20px;
    height: 20px;
}

.sheet-foldout > .unity-foldout__content {
    margin-left: 0;
    padding-left: 0;
}
/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   Assembly Section (Inside Sheet)
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.assembly-section {
    margin-top: 16px;
    padding-top: 16px;
    border-top-width: 1px;
    border-top-color: rgba(255, 255, 255, 0.06);
}

.section-title {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.65);
    letter-spacing: 4px;
    -unity-font-style: bold;
    margin-bottom: 8px;
}

.data-value-stars {
    color: rgb(255, 149, 7);
}

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   Shader Menu (Phase 1 â€” Long Press Popup)
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
/* Old shader-menu and env-panel styles removed (replaced by .submenu-container) */

/* Inline slider row (shown below card grid for Explode) */
.explode-inline-slider {
    width: 100%;
    margin-top: 8px;
    padding: 0 16px;
    flex-direction: row;
    align-items: center;
    justify-content: center;
}

.explosion-value-label {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.5);
    min-width: 40px;
    -unity-text-align: middle-right;
    margin-left: 8px;
}

.env-slider-group {
    width: 476px;
    height: 56px;
    align-self: center;
    margin-top: 8px;
    padding: 0 16px;

    background-color: transparent;
    border-width: 0;

    flex-direction: row;
    align-items: center;
}

.env-slider-label {
    font-size: 18px;
    color: rgba(255, 255, 255, 0.65);
    letter-spacing: 1px;
    margin-right: 12px;
    margin-bottom: 0;
    -unity-font-style: bold;
    white-space: nowrap;
    flex-shrink: 0;
}

.env-slider {
    flex-grow: 1;
    min-height: 44px;
}

/* Popup Blocker */
.popup-blocker {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    right: 0;
    background-color: transparent;
}

.popup-blocker--hidden {
    display: none;
}

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   Hero Menu (Phase 4)
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.hero-menu {
    flex-direction: column;
    align-items: center;
}

.hero-menu > .btn {
    margin-bottom: 16px;
}

.hero--hidden {
    opacity: 0;

    transition-property: opacity;
    transition-duration: 0.5s;
}

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   About Panel (Phase 4)
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.about-panel {
    position: absolute;
    left: 50%;
    top: 50%;
    translate: -50% -50%;
    width: 500px;
    background-color: rgba(0, 0, 0, 0.96);
    border-radius: 12px;
    padding: 40px;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
    align-items: center;
    opacity: 1;
    transition-property: opacity, scale;
    transition-duration: 0.3s;
}

.about-panel--hidden {
    display: none;
}

.about-title {
    font-size: 28px;
    -unity-font-style: bold;
    color: white;
    margin-bottom: 16px;
}

.about-desc {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.35);
    white-space: normal;
    -unity-text-align: middle-center;
    margin-bottom: 16px;
}

.about-credit {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.6);
}

.about-separator {
    height: 1px;
    background-color: rgba(255, 255, 255, 0.08);
    margin-top: 24px;
    margin-bottom: 24px;
    width: 100%;
}

.about-close {
    position: absolute;
    top: 16px;
    right: 16px;
}

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   Device Selector (Hero submenu)
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.device-selector {
    margin-top: 24px;
    width: 400px;
    background-color: rgba(1, 1, 1, 0.92);
    border-radius: 12px;
    padding: 12px;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.1);
    align-items: stretch;
    opacity: 1;
    scale: 1 1;
    transition-property: opacity, scale;
    transition-duration: 0.25s;
    transition-timing-function: ease-out;
}

.device-selector--hidden {
    display: none;
}


/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   Global Scrollbar Hiding
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.unity-scroller {
    display: none;
    width: 0;
    height: 0;
    opacity: 0;
}

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   Submenu Content Styles
   â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.submenu-scroll {
    width: 100%;
    max-width: 400px;
    overflow: hidden;
    align-self: center; /* Ensure scrollview itself is centered */
}

.submenu-scroll #unity-content-container {
    width: 100%;
    align-items: stretch;
    padding: 0;
    margin: 0;
}

.about-desc {
    font-size: 20px;
    color: rgba(255, 255, 255, 0.35);
    white-space: normal;
    -unity-text-align: upper-center;
    margin-bottom: 16px;
}

.about-credit {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.35);
    -unity-text-align: upper-center;
    letter-spacing: 2px;
    margin-bottom: 32px;
}

.device-option {
    width: 100%;
    height: 64px;
    min-height: 64px;
    flex-shrink: 0;
    margin-bottom: 12px;
    padding: 0 24px;
    font-size: 20px;
    
    background-color: rgba(255, 255, 255, 0.05);
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.1);
    border-radius: 28px;
    
    color: rgba(255, 255, 255, 0.8);
    justify-content: flex-start;
    align-items: center;
    transition-duration: 0.2s;
}

/* Device scroll â€” ensure enough height for all buttons */
.device-scroll {
    min-height: 280px;
    max-height: 50%;
    overflow: scroll;
    flex-shrink: 1;
}

.device-scroll #unity-content-container {
    padding: 0 4px 16px 4px;
}

.device-option:hover {
    background-color: rgba(255, 255, 255, 0.1);
    border-color: white;
}

.device-option--active {
    background-color: rgba(255, 255, 255, 0.1);
    border-color: white;
    color: white;
    -unity-font-style: bold;
}

.device-option:disabled {
    opacity: 0.25;
    color: rgba(255, 255, 255, 0.3);
}

/* ═══════════════════════════════════════════════════
   Onboarding Help Overlay
   ═══════════════════════════════════════════════════ */

.onboard-overlay {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.72);
    align-items: center;
    justify-content: center;
    opacity: 1;
    transition: opacity 0.3s ease;
}

.onboard-overlay--hidden {
    opacity: 0;
}

.onboard-card {
    background-color: rgba(28, 28, 32, 0.92);
    border-radius: 20px;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
    padding: 36px 40px 28px 40px;
    width: 380px;
    align-items: center;
}

/* Step counter ─────────────────────────────── */

.onboard-counter {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.4);
    letter-spacing: 2px;
    -unity-text-align: upper-center;
    margin-bottom: 20px;
    -unity-font-style: bold;
}

/* Icon area ────────────────────────────────── */

.onboard-icon-area {
    width: 88px;
    height: 88px;
    border-radius: 44px;
    background-color: rgba(255, 255, 255, 0.06);
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.06);
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
}

.onboard-icon {
    font-size: 36px;
    -unity-text-align: middle-center;
    color: white;
}

/* Text ─────────────────────────────────────── */

.onboard-title {
    font-size: 18px;
    color: white;
    -unity-font-style: bold;
    letter-spacing: 1px;
    -unity-text-align: upper-center;
    margin-bottom: 8px;
}

.onboard-desc {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.6);
    -unity-text-align: upper-center;
    white-space: normal;
    margin-bottom: 24px;
    max-width: 300px;
}

/* Progress dots ────────────────────────────── */

.onboard-dots {
    flex-direction: row;
    justify-content: center;
    align-items: center;
    margin-bottom: 28px;
}

.onboard-dot {
    width: 8px;
    height: 8px;
    border-radius: 4px;
    background-color: rgba(255, 255, 255, 0.15);
    margin-left: 4px;
    margin-right: 4px;
    transition: background-color 0.25s ease, scale 0.25s ease;
}

.onboard-dot--active {
    background-color: white;
    scale: 1.25 1.25;
}

/* Actions row ──────────────────────────────── */

.onboard-actions {
    flex-direction: row;
    justify-content: center;
    align-items: center;
    width: 100%;
}

.onboard-skip-btn {
    min-width: 100px;
    height: 44px;
    margin-right: 12px;
    font-size: 14px;
}

.onboard-next-btn {
    min-width: 140px;
    height: 44px;
    font-size: 14px;
}

/* ═══ Info Bar Peek (Bottom Sheet Pre-peek) ═══ */

.info-bar-peek {
    position: absolute;
    bottom: 0;
    left: 50%;
    translate: -50% 100%; /* Hidden off-screen bottom by default */
    width: 240px;
    height: 40px;
    background-color: rgba(0, 0, 0, 0.96);
    border-top-left-radius: 16px;
    border-top-right-radius: 16px;
    border-top-width: 1px;
    border-left-width: 1px;
    border-right-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
    align-items: center;
    justify-content: flex-start;
    padding-top: 8px;
    transition-property: translate, background-color, width, border-color;
    transition-duration: 0.3s;
    transition-timing-function: ease-out;
}

.info-bar-peek:hover {
    background-color: rgba(20, 20, 20, 0.98);
    border-color: rgba(255, 255, 255, 0.15);
    height: 44px;
}

.info-bar-peek:active {
    background-color: rgba(30, 30, 30, 1);
    height: 48px;
}

.info-bar-peek--visible {
    translate: -50% 0; /* Slide up, fully visible against bottom edge */
}

.info-bar-peek--hidden {
    translate: -50% 100%;
    opacity: 0;
    pointer-events: none;
}

/* When sheet is fully open, peek slides up behind the pill bar (hidden under it) */
.info-bar-peek--sheet-open {
    translate: -50% -100%;
    opacity: 0;
    pointer-events: none;
}

.peek-handle {
    width: 32px;
    height: 4px;
    background-color: rgba(255, 255, 255, 0.2);
    border-radius: 2px;
    margin-bottom: 4px;
}

.peek-label {
    font-size: 11px;
    color: rgba(255, 255, 255, 0.4);
    letter-spacing: 2px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
}

/* =======================================================
   Sheet Close Button ("X") - Apple HIG / Material 3
   Placed absolute right within the relative header.
   ======================================================= */
.sheet-close-btn {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 44px;
    height: 44px;
    border-radius: 22px;
    background-color: rgba(255, 255, 255, 0.05);
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.6);
    font-size: 18px;
    -unity-text-align: middle-center;
    padding: 0;
    margin: 0;
    transition-property: background-color, scale, color;
    transition-duration: 0.2s;
}

.sheet-close-btn:hover {
    background-color: rgba(255, 255, 255, 0.15);
    color: rgb(255, 255, 255);
}

.sheet-close-btn:active {
    scale: 0.92;
    background-color: rgba(255, 255, 255, 0.25);
}
