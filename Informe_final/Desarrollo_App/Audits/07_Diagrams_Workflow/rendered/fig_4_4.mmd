flowchart LR
    subgraph I1[Entrada y validacion]
      direction TB
      A[Usuario mueve o clickea puntero]
      B{Input bloqueado por UI?}
      Z[Ignorar seleccion en este frame]
    end

    subgraph I2[Deteccion de objetivo]
      direction TB
      C[SelectionManager.HandleHover]
      D[Raycast sobre selectionLayer]
      E{Impacta objeto seleccionable?}
      F[ClearHover + cursor default]
      G[Hover valido + HighlightSystem.OnHoverEnter]
    end

    subgraph I3[Resolucion de click]
      direction TB
      H{Click primario?}
      I{Doble click en umbral?}
      J[Publish PartDoubleClickedEvent]
      K{Hover es null al click?}
      L[Deselect, publish PartSelectedEvent null]
      M[SelectObject, apply Highlight OnSelect]
      N[Resolve ExplodablePart data]
      P[Publish PartSelectedEvent data]
    end

    subgraph I4[Reacciones del sistema]
      direction TB
      Q["UIManager + UIDetailsSheet (bottom sheet visible)"]
      R[AnalyticsManager.TrackPartSelected]
      S[Audio hooks opcionales]
      T[Acciones avanzadas por doble click: focus o isolate segun contexto]
    end

    A --> B
    B -- Si --> Z
    B -- No --> C
    C --> D
    D --> E
    E -- No --> F
    E -- Si --> G
    G --> H
    H -- No --> C
    H -- Si --> I
    I -- Si --> J
    J --> T
    I -- No --> K
    K -- Si --> L
    K -- No --> M
    M --> N
    N --> P

    P --> Q
    P --> R
    P -.-> S

    classDef ui fill:#eaf2fb,stroke:#3b6ea5,color:#102033,stroke-width:1.5px;
    classDef orch fill:#e9f7ef,stroke:#2f7d4c,color:#10311c,stroke-width:2px;
    classDef svc fill:#fff1e6,stroke:#b56a1e,color:#4b2b08,stroke-width:1.5px;
    classDef data fill:#f2ecfb,stroke:#7a59b5,color:#281642,stroke-width:1.5px;
    classDef event fill:#f7e9fa,stroke:#a44fb3,color:#45154a,stroke-width:1.5px;
    classDef state fill:#e7f6f7,stroke:#21797a,color:#123536,stroke-width:1.5px;
    classDef risk fill:#fdeaea,stroke:#c23b3b,color:#5a1515,stroke-width:2px;
    classDef mitigation fill:#edf3ff,stroke:#5877c6,color:#1b2d57,stroke-width:1.5px;
    classDef result fill:#e8f8ef,stroke:#2d8a57,color:#123322,stroke-width:1.5px;
    classDef neutral fill:#f3f5f7,stroke:#677788,color:#17212b,stroke-width:1.5px;

    class A,Q ui;
    class C,D,G,M,N orch;
    class B,E,H,I,K neutral;
    class Z,F,T mitigation;
    class J,P event;
    class L state;
    class R result;
    class S neutral;


